{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local", ".env"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "typecheck": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production.local", ".env.local", ".env.production", ".env"]
    },
    "test:e2e": {
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:integration": {
      "cache": false,
      "env": ["DATABASE_URL", "INTEGRATION_DATABASE_URL"]
    },
    "test:unit": {
      "cache": false
    },
    "paraglide:compile": {},
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "api:start": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
