    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/engine": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/queue": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
