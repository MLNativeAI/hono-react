{
  "name": "hono-react",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:e2e": "turbo test:e2e",
    "test:integration": "turbo test:integration",
    "test:unit": "turbo test:unit",
    "paraglide:compile": "turbo paraglide:compile",
    "docker": "docker build -f apps/api/Dockerfile -t hono-react-api . && docker build -f apps/dashboard/Dockerfile -t hono-react-dashboard .",
    "deploy:staging": "gh workflow run deploy-staging.yml --ref $(git branch --show-current)",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "init": "bun run scripts/init-env.ts",
    "clean": "turbo daemon stop && rm -rf .turbo node_modules **/node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "turbo": "^2.9.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tests/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "^0.13.11",
      "@types/bun": "^1.3.14",
      "@types/node": "^25.9.3",
      "better-auth": "^1.6.18",
      "date-fns": "^4.4.0",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "hono": "^4.12.25",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "typescript": "~6.0.3",
      "pino": "^10.3.1",
      "pino-pretty": "^13.0.0",
      "zod": "^4.4.3"
    }
  },
  "version": "1.7.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
