{
  "name": "hono-react",
  "packageManager": "bun@1.3.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:e2e": "turbo test:e2e",
    "test:e2e:smoke": "turbo test:e2e:smoke",
    "test:e2e:acc": "turbo test:e2e:acc",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "docker": "docker compose -f docker-compose.prod.yml build  && docker compose -f docker-compose.prod.yml up -d",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "init": "bun run scripts/init-env.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tests/*"
    ],
    "catalog": {
      "better-auth": "^1.4.13",
      "hono": "^4.9.10",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "zod": "^4.0.0"
    }
  },
  "version": "1.7.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
